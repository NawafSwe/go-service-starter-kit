GENERAL__SERVICE_NAME=go-backend-template
GENERAL__APP_VERSION=1.0.0
GENERAL__APP_ENVIRONMENT=test
GENERAL__LOG_LEVEL=error
GENERAL__TRACING__ENABLED=false

HTTP__PORT=0
HTTP__SHUTDOWN_TIMEOUT=5s
HTTP__READ_TIMEOUT=10s
HTTP__READ_HEADER_TIMEOUT=5s
HTTP__WRITE_TIMEOUT=10s

GRPC__PORT=0
GRPC__SHUTDOWN_TIMEOUT=5s

DB__DSN=postgres://postgres:postgres@localhost:5432/appdb?sslmode=disable
DB__MAX_OPEN_CONNECTIONS=5
DB__MAX_IDLE_CONNECTIONS=2
DB__MAX_CONNECTIONS_LIFETIME=1h

JWT__SECRET=integration-test-secret
JWT__TTL=1h
JWT__ISSUER=go-backend-template

METRICS__ENABLED=false

AUTHORIZATION_MOCK__ENABLED=false
