GENERAL__SERVICE_NAME=go-backend-template
GENERAL__APP_VERSION=1.0.0
GENERAL__APP_ENVIRONMENT=development
GENERAL__LOG_LEVEL=debug
GENERAL__TRACING__ENABLED=false
GENERAL__TRACING__RECEIVER_ENDPOINT=

HTTP__PORT=8080
HTTP__SHUTDOWN_TIMEOUT=15s
HTTP__READ_TIMEOUT=10s
HTTP__READ_HEADER_TIMEOUT=5s
HTTP__WRITE_TIMEOUT=10s

GRPC__PORT=50051
GRPC__SHUTDOWN_TIMEOUT=15s

CONSUMER__BROKERS=localhost:9092
CONSUMER__GROUP_ID=go-backend-kit-consumer
CONSUMER__TOPICS=example.events

DB__DSN=postgres://postgres:postgres@localhost:5432/appdb?sslmode=disable
DB__MAX_OPEN_CONNECTIONS=10
DB__MAX_IDLE_CONNECTIONS=5
DB__MAX_CONNECTIONS_LIFETIME=1h

JWT__SECRET=change-me-in-production
JWT__TTL=24h
JWT__ISSUER=go-backend-template

METRICS__ENABLED=false

AUTHORIZATION_MOCK__ENABLED=false
AUTHORIZATION_MOCK__USER_ID=
AUTHORIZATION_MOCK__DEVICE_ID=
